{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "types": ["node"],
    "paths": {
      "@/*": ["./src/*"],
      "@acronis-platform/shadcn-uikit": [
        "../../packages/ui-legacy/dist/index.d.ts"
      ],
      "@acronis-platform/shadcn-uikit/react": [
        "../../packages/ui-legacy/dist/react.d.ts"
      ],
      "@acronis-platform/shadcn-uikit/styles": [
        "../../packages/ui-legacy/src/styles/globals.css"
      ],
      "@uikit-utils/*": ["../../packages/ui-legacy/dist/utils/*"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
